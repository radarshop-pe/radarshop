<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Radarshop — Panel de gestión</title>
<link rel="icon" type="apple-touch-icon" href="\Radarshop\app\instance\img\radar.png">
<link rel="apple-touch-icon" href="\Radarshop\app\instance\img\radar.png">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--orange:#FE7301;--orange-dark:#d46000;--orange-light:#fff0e6;--orange-text:#7a3500;--green:#1D9E75;--green-dark:#0F6E56;--green-light:#E1F5EE;--green-text:#085041;--amber:#EF9F27;--amber-light:#FAEEDA;--amber-text:#854F0B;--red:#E24B4A;--red-light:#FCEBEB;--red-text:#A32D2D;--blue-light:#E6F1FB;--blue-text:#185FA5;--bg:#F5F3EF;--surface:#FFFFFF;--border:rgba(0,0,0,0.07);--border-md:rgba(0,0,0,0.12);--text:#1A1A18;--text-2:#6B6A66;--text-3:#A8A7A3;--r:10px;--r-lg:14px}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);font-size:14px;display:flex;height:100vh;overflow:hidden}
.sidebar{width:230px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;height:100vh;flex-shrink:0}
.sb-head{padding:20px 16px 14px;border-bottom:1px solid var(--border)}
.brand{display:flex;align-items:center;gap:10px}
.brand-icon{width:34px;height:34px;background:var(--orange);border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.brand-icon svg{width:19px;height:19px}
.brand-name{font-size:15px;font-weight:600}
.brand-sub{font-size:11px;color:var(--text-3);margin-top:1px}
.sb-nav{flex:1;padding:12px 10px;overflow-y:auto}
.nav-section{font-size:10px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.08em;padding:0 6px;margin:14px 0 4px}
.nav-section:first-child{margin-top:0}
.ni{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:8px;color:var(--text-2);cursor:pointer;transition:all .14s;font-size:13.5px;border:none;background:none;width:100%;text-align:left}
.ni svg{width:16px;height:16px;flex-shrink:0;opacity:.7}
.ni:hover{background:var(--bg);color:var(--text)}
.ni.on{background:var(--orange-light);color:var(--orange-text);font-weight:500}
.ni.on svg{opacity:1}
.ni .nc{margin-left:auto;font-size:10px;background:var(--red);color:#fff;border-radius:10px;padding:1px 7px;font-weight:600}
.sb-foot{padding:12px;border-top:1px solid var(--border)}
.exp-btn{width:100%;padding:10px;background:var(--orange);color:#fff;border:none;border-radius:var(--r);font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;transition:background .15s}
.exp-btn:hover{background:var(--orange-dark)}
.exp-btn svg{width:15px;height:15px}
.main{flex:1;overflow-y:auto;padding:32px 36px}
.page-hd{margin-bottom:1.75rem}
.page-title{font-size:22px;font-weight:600}
.page-sub{font-size:13px;color:var(--text-2);margin-top:3px}
.section{display:none}
.section.on{display:block}
.kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:1.75rem}
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px 18px}
.kpi-label{font-size:12px;color:var(--text-2);margin-bottom:6px;font-weight:500}
.kpi-val{font-size:28px;font-weight:600;line-height:1;color:var(--text)}
.kpi-val.g{color:var(--green-dark)}.kpi-val.r{color:var(--red-text)}.kpi-val.o{color:var(--orange-dark)}
.kpi-sub{font-size:11px;color:var(--text-3);margin-top:5px}
.kpi-bar{height:3px;background:var(--bg);border-radius:2px;margin-top:10px;overflow:hidden}
.kpi-fill{height:100%;background:var(--orange);border-radius:2px;transition:width .5s}
.kpi-fill.g{background:var(--green)}
.dash-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px}
.dash-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:18px}
.dash-card-title{font-size:11px;font-weight:600;color:var(--text-2);margin-bottom:12px;text-transform:uppercase;letter-spacing:.06em}
.top-item{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid var(--border)}
.top-item:last-child{border-bottom:none}
.top-rank{font-size:11px;font-weight:600;color:var(--text-3);width:18px}
.top-name{flex:1;font-size:13px;font-weight:500}
.top-val{font-size:13px;color:var(--green-dark);font-weight:600}
.top-qty{font-size:11px;color:var(--text-3);margin-left:5px}
.ch-item{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.ch-name{font-size:13px;width:150px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ch-bar-wrap{flex:1;height:8px;background:var(--bg);border-radius:4px;overflow:hidden}
.ch-bar{height:100%;background:var(--orange);border-radius:4px;transition:width .5s}
.ch-n{font-size:12px;color:var(--text-2);width:22px;text-align:right}
.toolbar{display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap;align-items:center}
.btn{padding:8px 15px;font-size:13px;font-family:'DM Sans',sans-serif;border:1px solid var(--border-md);border-radius:var(--r);background:var(--surface);color:var(--text);cursor:pointer;transition:all .14s;display:inline-flex;align-items:center;gap:6px;white-space:nowrap}
.btn:hover{background:var(--bg)}
.btn-p{background:var(--orange);color:#fff;border-color:var(--orange)}.btn-p:hover{background:var(--orange-dark);border-color:var(--orange-dark)}
.btn-sm{padding:5px 10px;font-size:12px}
.btn-edit{border-color:var(--blue-text);color:var(--blue-text)}.btn-edit:hover{background:var(--blue-light)}
.btn-del{border-color:var(--red);color:var(--red-text);background:none}.btn-del:hover{background:var(--red-light)}
.btn-ghost{border-color:var(--border-md);color:var(--text-2)}
.srch{flex:1;min-width:180px;padding:8px 12px;font-size:13px;font-family:'DM Sans',sans-serif;border:1px solid var(--border-md);border-radius:var(--r);background:var(--surface);color:var(--text);outline:none;transition:border-color .15s}
.srch:focus{border-color:var(--orange)}
.sel-f{padding:8px 12px;font-size:13px;font-family:'DM Sans',sans-serif;border:1px solid var(--border-md);border-radius:var(--r);background:var(--surface);color:var(--text);cursor:pointer;outline:none}
.fcard{background:var(--surface);border:1px solid var(--border-md);border-radius:var(--r-lg);padding:20px;margin-bottom:18px;display:none}
.fcard.on{display:block;animation:fadeIn .15s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
.ftitle{font-size:15px;font-weight:600;margin-bottom:16px}
.fgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:13px}
.fgrid-2{display:grid;grid-template-columns:1fr 1fr;gap:13px}
.field{display:flex;flex-direction:column;gap:5px}
.field label{font-size:12px;color:var(--text-2);font-weight:500}
.field input,.field select,.field textarea{padding:8px 11px;font-size:13px;font-family:'DM Sans',sans-serif;border:1px solid var(--border-md);border-radius:var(--r);background:var(--bg);color:var(--text);outline:none;transition:border-color .15s}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--orange);background:var(--surface)}
.ffield{grid-column:1/-1}
.ffoot{display:flex;gap:10px;margin-top:16px;justify-content:flex-end;border-top:1px solid var(--border);padding-top:14px}
.step-box{background:var(--bg);border-radius:var(--r);padding:14px;margin-bottom:14px}
.step-label{font-size:11px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px}
.sale-row{display:grid;grid-template-columns:1fr 90px 110px 36px;gap:8px;align-items:center;margin-bottom:8px}
.sale-row input,.sale-row select{padding:7px 10px;font-size:13px;font-family:'DM Sans',sans-serif;border:1px solid var(--border-md);border-radius:var(--r);background:var(--surface);color:var(--text);outline:none;width:100%}
.sale-row input:focus,.sale-row select:focus{border-color:var(--orange)}
.rm-btn{border:none;background:none;color:var(--red-text);cursor:pointer;font-size:20px;line-height:1;padding:0}
.add-line{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--orange);border:none;background:none;cursor:pointer;padding:4px 0;font-weight:500}
.sale-total-row{text-align:right;font-size:13px;color:var(--text-2);margin-top:8px}
.sale-total-row strong{color:var(--text);font-size:15px}
.cli-wrap{position:relative}
.cli-dd{position:absolute;top:100%;left:0;right:0;background:var(--surface);border:1px solid var(--border-md);border-radius:var(--r);z-index:50;max-height:200px;overflow-y:auto;display:none;box-shadow:0 4px 12px rgba(0,0,0,.1)}
.cli-dd.on{display:block}
.cli-opt{padding:9px 12px;cursor:pointer;font-size:13px;border-bottom:1px solid var(--border)}
.cli-opt:last-child{border-bottom:none}
.cli-opt:hover{background:var(--bg)}
.cli-opt-name{font-weight:500}
.cli-opt-sub{font-size:11px;color:var(--text-3)}
.alert-banner{background:var(--amber-light);border:1px solid var(--amber);border-radius:var(--r);padding:10px 14px;font-size:13px;color:var(--amber-text);margin-bottom:14px;display:flex;align-items:center;gap:8px}
.tw{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden;overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:var(--bg);padding:10px 13px;text-align:left;font-size:11px;font-weight:600;color:var(--text-2);border-bottom:1px solid var(--border);white-space:nowrap;text-transform:uppercase;letter-spacing:.05em}
td{padding:11px 13px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(254,115,1,.02)}
.cn{font-weight:500}.cc{font-family:'DM Mono',monospace;font-size:11px;color:var(--text-3);display:block;margin-top:2px}
.badge{display:inline-flex;align-items:center;padding:2px 9px;border-radius:20px;font-size:11.5px;font-weight:500}
.bg{background:var(--green-light);color:var(--green-text)}.ba{background:var(--amber-light);color:var(--amber-text)}.br{background:var(--red-light);color:var(--red-text)}.bb{background:var(--blue-light);color:var(--blue-text)}.bo{background:var(--orange-light);color:var(--orange-text)}.bgr{background:var(--bg);color:var(--text-2)}
.empty{text-align:center;padding:3.5rem 2rem;color:var(--text-2)}
.empty-icon{font-size:2.5rem;margin-bottom:12px;opacity:.4}
.empty p{font-size:14px;margin-bottom:16px}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:200;display:none;align-items:center;justify-content:center}
.modal-bg.on{display:flex}
.modal{background:var(--surface);border-radius:var(--r-lg);padding:24px;width:min(96vw,560px);max-height:90vh;overflow-y:auto;animation:fadeIn .18s ease}
.modal-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.modal-title{font-size:16px;font-weight:600}
.modal-close{border:none;background:none;font-size:22px;cursor:pointer;color:var(--text-2);line-height:1}
.modal-close:hover{color:var(--text)}
.stars{color:var(--amber);font-size:13px;letter-spacing:1px}
.toast{position:fixed;bottom:24px;right:24px;background:var(--text);color:#fff;padding:12px 18px;border-radius:var(--r);font-size:13px;font-weight:500;transform:translateY(80px);opacity:0;transition:all .25s;z-index:999;display:flex;align-items:center;gap:8px;max-width:340px}
.toast.show{transform:translateY(0);opacity:1}
.toast.ok{background:var(--green-dark)}.toast.er{background:var(--red-text)}
</style>
</head>
<body>

<aside class="sidebar">
  <div class="sb-head">
    <div class="brand">
      <div class="brand-icon"><svg viewBox="0 0 19 19" fill="none"><circle cx="9.5" cy="9.5" r="7.5" stroke="white" stroke-width="1.5"/><circle cx="9.5" cy="9.5" r="3.8" stroke="white" stroke-width="1.5"/><circle cx="9.5" cy="9.5" r="1.4" fill="white"/></svg></div>
      <div><div class="brand-name">Radarshop</div><div class="brand-sub">A un click de tu compra</div></div>
    </div>
  </div>
  <nav class="sb-nav">
    <div class="nav-section">Principal</div>
    <button class="ni on" onclick="go('dashboard',this)"><svg viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/><rect x="9" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/><rect x="1" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/><rect x="9" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/></svg>Dashboard</button>
    <button class="ni" onclick="go('inventario',this)"><svg viewBox="0 0 16 16" fill="none"><path d="M2 4.5h12M2 8h9M2 11.5h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>Inventario<span class="nc" id="badge-stock" style="display:none">0</span></button>
    <button class="ni" onclick="go('ventas',this)"><svg viewBox="0 0 16 16" fill="none"><path d="M2 12L6 7l3 3 5-6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>Ventas</button>
    <div class="nav-section">Gestión</div>
    <button class="ni" onclick="go('clientes',this)"><svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="5.5" r="3" stroke="currentColor" stroke-width="1.4"/><path d="M2 14c0-3 2.686-4.5 6-4.5s6 1.5 6 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>Clientes</button>
    <button class="ni" onclick="go('consultas',this)"><svg viewBox="0 0 16 16" fill="none"><path d="M2 3a1 1 0 011-1h10a1 1 0 011 1v7a1 1 0 01-1 1H9l-3 3v-3H3a1 1 0 01-1-1V3z" stroke="currentColor" stroke-width="1.4"/></svg>Consultas</button>
    <button class="ni" onclick="go('proveedores',this)"><svg viewBox="0 0 16 16" fill="none"><path d="M1 5l5-3 4 2.5L15 2v10l-5 2.5-4-2.5L1 14V5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>Proveedores</button>
    <div class="nav-section">Config</div>
    <button class="ni" onclick="go('categorias',this)"><svg viewBox="0 0 16 16" fill="none"><path d="M2 2h5v5H2zM9 2h5v5H9zM2 9h5v5H2zM9 9h5v5H9z" stroke="currentColor" stroke-width="1.4"/></svg>Categorías</button>
  </nav>
  <div class="sb-foot">
    <button class="exp-btn" onclick="exportExcel()"><svg viewBox="0 0 16 16" fill="none"><path d="M8 2v9M4 8l4 4 4-4M2 13h12" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Exportar a Excel</button>
  </div>
</aside>

<main class="main">
  <!-- DASHBOARD -->
  <section id="sec-dashboard" class="section on">
    <div class="page-hd"><div class="page-title">Dashboard</div><div class="page-sub">Resumen general del negocio en tiempo real</div></div>
    <div class="kpis" id="kpi-dash"></div>
    <div class="dash-grid">
      <div class="dash-card"><div class="dash-card-title">Top productos por ventas</div><div id="top-products"><div class="empty"><p>Sin ventas aún</p></div></div></div>
      <div class="dash-card"><div class="dash-card-title">Ventas por canal</div><div id="channels-chart"><div class="empty"><p>Sin ventas aún</p></div></div></div>
    </div>
  </section>

  <!-- INVENTARIO -->
  <section id="sec-inventario" class="section">
    <div class="page-hd"><div class="page-title">Inventario</div><div class="page-sub">Productos, precios, stock y márgenes</div></div>
    <div class="kpis" id="kpi-inv"></div>
    <div id="alert-inv" class="alert-banner" style="display:none">⚠️ Hay productos con stock por debajo del mínimo.</div>
    <div class="toolbar">
      <button class="btn btn-p" onclick="openF('finv')">+ Agregar producto</button>
      <input class="srch" placeholder="Buscar por nombre, SKU..." oninput="filterTb('tb-inv',this.value)">
      <select class="sel-f" id="filter-cat" onchange="filterCol('tb-inv',2,this.value)"><option value="">Todas las categorías</option></select>
    </div>
    <div id="finv" class="fcard">
      <div class="ftitle" id="finv-title">Nuevo producto</div>
      <input type="hidden" id="fi-id">
      <div class="fgrid">
        <div class="field"><label>Nombre *</label><input id="fi-name" placeholder="Ej: Organizador escritorio"/></div>
        <div class="field"><label>Categoría</label><select id="fi-cat"><option value="">Seleccionar...</option></select></div>
        <div class="field"><label>Color</label><input id="fi-color" placeholder="Ej: Negro"/></div>
        <div class="field"><label>Proveedor</label><select id="fi-prov"><option value="">Seleccionar...</option></select></div>
        <div class="field"><label>Costo unitario (S/) *</label><input id="fi-cost" type="number" placeholder="0.00" step="0.01" oninput="calcMargin()"/></div>
        <div class="field"><label>Precio venta (S/) *</label><input id="fi-retail" type="number" placeholder="0.00" step="0.01" oninput="calcMargin()"/></div>
        <div class="field"><label>Precio mayorista (S/)</label><input id="fi-wholesale" type="number" placeholder="0.00" step="0.01"/></div>
        <div class="field"><label>Stock actual</label><input id="fi-stock" type="number" placeholder="0"/></div>
        <div class="field"><label>Stock mínimo</label><input id="fi-smin" type="number" placeholder="1"/></div>
        <div class="field"><label>Ubicación</label><input id="fi-loc" placeholder="Ej: Estante A2"/></div>
        <div class="field"><label>Margen estimado</label><input id="fi-margin" readonly style="background:var(--bg);color:var(--green-dark);font-weight:600"/></div>
        <div class="field ffield"><label>Notas</label><input id="fi-notes" placeholder="Observaciones opcionales"/></div>
      </div>
      <div class="ffoot">
        <button class="btn btn-ghost" onclick="closeF('finv');resetProductForm()">Cancelar</button>
        <button class="btn btn-p" onclick="saveProduct()">Guardar producto</button>
      </div>
    </div>
    <div class="tw"><table><thead><tr><th style="width:22%">Producto</th><th style="width:11%">Categoría</th><th style="width:9%">Costo</th><th style="width:9%">P.Venta</th><th style="width:9%">Margen</th><th style="width:8%">Stock</th><th style="width:10%">Proveedor</th><th style="width:8%">Estado</th><th style="width:14%">Acciones</th></tr></thead><tbody id="tb-inv"></tbody></table></div>
    <div id="empty-inv" class="empty"><div class="empty-icon">📦</div><p>Sin productos aún.</p><button class="btn btn-p" onclick="openF('finv')">+ Agregar producto</button></div>
  </section>

  <!-- VENTAS -->
  <section id="sec-ventas" class="section">
    <div class="page-hd"><div class="page-title">Ventas</div><div class="page-sub">Valida cliente, agrega productos y descuenta stock automáticamente</div></div>
    <div class="kpis" id="kpi-ventas"></div>
    <div class="toolbar">
      <button class="btn btn-p" onclick="openF('fventa')">+ Registrar venta</button>
      <input class="srch" placeholder="Buscar por cliente o producto..." oninput="filterTb('tb-ventas',this.value)">
    </div>
    <div id="fventa" class="fcard">
      <div class="ftitle">Registrar venta</div>
      <div class="step-box">
        <div class="step-label">1 — Cliente</div>
        <div class="fgrid-2">
          <div class="field cli-wrap">
            <label>Buscar cliente (nombre o teléfono)</label>
            <input id="fv-cli-search" placeholder="Escribe para buscar..." oninput="searchClient(this.value)" autocomplete="off"/>
            <div class="cli-dd" id="cli-dd"></div>
          </div>
          <div class="field">
            <label>Seleccionado</label>
            <input id="fv-cli-display" readonly placeholder="(ninguno)" style="background:var(--surface)"/>
            <input type="hidden" id="fv-cli-id"/>
          </div>
        </div>
        <div style="margin-top:10px;font-size:12px;color:var(--text-2)">¿Cliente nuevo? <button class="btn btn-sm" onclick="openModal('modal-cli')" style="font-size:12px;padding:4px 10px;margin-left:4px">+ Crear cliente rápido</button></div>
      </div>
      <div class="step-box">
        <div class="step-label">2 — Productos</div>
        <div style="display:grid;grid-template-columns:1fr 90px 110px 36px;gap:8px;margin-bottom:6px"><span style="font-size:11px;color:var(--text-3);font-weight:600">PRODUCTO</span><span style="font-size:11px;color:var(--text-3);font-weight:600">CANT.</span><span style="font-size:11px;color:var(--text-3);font-weight:600">PRECIO (S/)</span><span></span></div>
        <div id="sale-items"></div>
        <button class="add-line" onclick="addSaleItem()">+ Agregar línea de producto</button>
        <div class="sale-total-row">Total estimado: <strong id="sale-total-val">S/ 0.00</strong></div>
      </div>
      <div class="fgrid">
        <div class="field"><label>Canal</label><select id="fv-channel"><option>Facebook Marketplace</option><option>Instagram</option><option>TikTok</option><option>WhatsApp</option><option>Tienda online</option><option>Referido</option></select></div>
        <div class="field"><label>Método de pago</label><select id="fv-payment"><option>Yape</option><option>Efectivo</option><option>Plin</option><option>Transferencia</option><option>Tarjeta</option></select></div>
        <div class="field"><label>Tipo de entrega</label><select id="fv-entrega"><option>Delivery courier</option><option>Delivery app</option><option>Recojo en punto de encuentro</option></select></div>
        <div class="field"><label>Delivery cobrado (S/)</label><input id="fv-delivery" type="number" placeholder="0" value="0" oninput="calcSaleTotal()"/></div>
        <div class="field ffield"><label>Notas</label><input id="fv-notes" placeholder="Observaciones opcionales"/></div>
      </div>
      <div class="ffoot">
        <button class="btn btn-ghost" onclick="closeF('fventa')">Cancelar</button>
        <button class="btn btn-p" onclick="saveSale()">Registrar venta</button>
      </div>
    </div>
    <div class="tw"><table><thead><tr><th style="width:10%">Fecha</th><th style="width:10%">ID</th><th style="width:15%">Cliente</th><th style="width:20%">Productos</th><th style="width:10%">Ingreso</th><th style="width:10%">Ganancia</th><th style="width:11%">Canal</th><th style="width:9%">Pago</th><th style="width:5%">Acc.</th></tr></thead><tbody id="tb-ventas"></tbody></table></div>
    <div id="empty-ventas" class="empty"><div class="empty-icon">💰</div><p>Sin ventas registradas.</p><button class="btn btn-p" onclick="openF('fventa')">+ Registrar venta</button></div>
  </section>

  <!-- CLIENTES -->
  <section id="sec-clientes" class="section">
    <div class="page-hd"><div class="page-title">Clientes</div><div class="page-sub">Base de datos y valor por cliente</div></div>
    <div class="kpis" id="kpi-cli"></div>
    <div class="toolbar"><button class="btn btn-p" onclick="openModal('modal-cli')">+ Agregar cliente</button><input class="srch" placeholder="Buscar por nombre, distrito..." oninput="filterTb('tb-cli',this.value)"></div>
    <div class="tw"><table><thead><tr><th style="width:20%">Nombre</th><th style="width:13%">Teléfono</th><th style="width:12%">Distrito</th><th style="width:9%">Pedidos</th><th style="width:13%">Total gastado</th><th style="width:9%">Estado</th><th style="width:11%">Registro</th><th style="width:13%">Acciones</th></tr></thead><tbody id="tb-cli"></tbody></table></div>
    <div id="empty-cli" class="empty"><div class="empty-icon">👥</div><p>Sin clientes registrados.</p><button class="btn btn-p" onclick="openModal('modal-cli')">+ Agregar cliente</button></div>
  </section>

  <!-- CONSULTAS -->
  <section id="sec-consultas" class="section">
    <div class="page-hd"><div class="page-title">Consultas</div><div class="page-sub">Mide tu tasa de conversión por canal y producto</div></div>
    <div class="kpis" id="kpi-inq"></div>
    <div class="toolbar"><button class="btn btn-p" onclick="openF('finq')">+ Registrar consulta</button><input class="srch" placeholder="Buscar..." oninput="filterTb('tb-inq',this.value)"></div>
    <div id="finq" class="fcard">
      <div class="ftitle">Registrar consulta</div>
      <div class="fgrid">
        <div class="field"><label>Producto consultado *</label><select id="fiq-prod"><option value="">Seleccionar producto...</option></select></div>
        <div class="field"><label>Cliente</label><input id="fiq-cli" placeholder="Nombre o alias"/></div>
        <div class="field"><label>Canal</label><select id="fiq-canal"><option>Facebook Marketplace</option><option>Instagram</option><option>TikTok</option><option>WhatsApp</option></select></div>
        <div class="field"><label>Pregunta clave</label><select id="fco-preg"><option>¿Cuánto cuesta?</option><option>¿Tienen en stock?</option><option>Ubicación</option></select></div>
        <div class="field"><label>Resultado</label><select id="fiq-res"><option>Compró</option><option>No compró</option><option>Pendiente</option></select></div>
        <div class="field"><label>Motivo de no compra</label><input id="fiq-mot" placeholder="Ej: precio alto, sin stock..."/></div>
      </div>
      <div class="ffoot"><button class="btn btn-ghost" onclick="closeF('finq')">Cancelar</button><button class="btn btn-p" onclick="saveInquiry()">Guardar consulta</button></div>
    </div>
    <div class="tw"><table><thead><tr><th style="width:10%">Fecha</th><th style="width:18%">Producto</th><th style="width:13%">Cliente</th><th style="width:12%">Canal</th><th style="width:22%">Pregunta</th><th style="width:11%">Resultado</th><th style="width:14%">Motivo</th></tr></thead><tbody id="tb-inq"></tbody></table></div>
    <div id="empty-inq" class="empty"><div class="empty-icon">💬</div><p>Registra cada consulta para analizar tu conversión.</p><button class="btn btn-p" onclick="openF('finq')">+ Registrar consulta</button></div>
  </section>

  <!-- PROVEEDORES -->
  <section id="sec-proveedores" class="section">
    <div class="page-hd"><div class="page-title">Proveedores</div><div class="page-sub">Directorio de importadores y mayoristas</div></div>
    <div class="toolbar"><button class="btn btn-p" onclick="openModal('modal-prov')">+ Agregar proveedor</button><input class="srch" placeholder="Buscar proveedor..." oninput="filterTb('tb-prov',this.value)"></div>
    <div class="tw"><table><thead><tr><th style="width:20%">Nombre</th><th style="width:14%">Contacto</th><th style="width:13%">Teléfono</th><th style="width:15%">Ubicación</th><th style="width:10%">Tipo</th><th style="width:10%">Calidad</th><th style="width:18%">Acciones</th></tr></thead><tbody id="tb-prov"></tbody></table></div>
    <div id="empty-prov" class="empty"><div class="empty-icon">🏭</div><p>Sin proveedores registrados.</p><button class="btn btn-p" onclick="openModal('modal-prov')">+ Agregar proveedor</button></div>
  </section>

  <!-- CATEGORÍAS -->
  <section id="sec-categorias" class="section">
    <div class="page-hd"><div class="page-title">Categorías</div><div class="page-sub">Organiza tu catálogo por categoría</div></div>
    <div class="toolbar"><button class="btn btn-p" onclick="openModal('modal-cat')">+ Nueva categoría</button></div>
    <div class="tw"><table><thead><tr><th style="width:8%">ID</th><th style="width:28%">Nombre</th><th style="width:36%">Descripción</th><th style="width:14%">Productos</th><th style="width:14%">Acciones</th></tr></thead><tbody id="tb-cat"></tbody></table></div>
    <div id="empty-cat" class="empty"><div class="empty-icon">🗂️</div><p>Sin categorías.</p></div>
  </section>
</main>

<!-- MODAL CLIENTE -->
<div class="modal-bg" id="modal-cli"><div class="modal">
  <div class="modal-head"><div class="modal-title" id="modal-cli-title">Nuevo cliente</div><button class="modal-close" onclick="closeModal('modal-cli')">×</button></div>
  <input type="hidden" id="mc-id">
  <div class="fgrid">
    <div class="field"><label>Nombre *</label><input id="mc-name" placeholder="Nombre completo"/></div>
    <div class="field"><label>Teléfono</label><input id="mc-phone" placeholder="9XXXXXXXX"/></div>
    <div class="field"><label>Distrito</label><input id="mc-district" placeholder="Ej: Miraflores"/></div>
    <div class="field"><label>Estado</label><select id="mc-status"><option>Activo</option><option>Frecuente</option><option>Inactivo</option></select></div>
    <div class="field ffield"><label>Notas</label><input id="mc-notes" placeholder="Observaciones..."/></div>
  </div>
  <div class="ffoot"><button class="btn btn-ghost" onclick="closeModal('modal-cli')">Cancelar</button><button class="btn btn-p" onclick="saveClient()">Guardar cliente</button></div>
</div></div>

<!-- MODAL PROVEEDOR -->
<div class="modal-bg" id="modal-prov"><div class="modal">
  <div class="modal-head"><div class="modal-title" id="modal-prov-title">Nuevo proveedor</div><button class="modal-close" onclick="closeModal('modal-prov')">×</button></div>
  <input type="hidden" id="mp-id">
  <div class="fgrid">
    <div class="field"><label>Nombre / Empresa *</label><input id="mp-name" placeholder="Nombre o razón social"/></div>
    <div class="field"><label>Contacto</label><input id="mp-contact" placeholder="Nombre del contacto"/></div>
    <div class="field"><label>Teléfono</label><input id="mp-phone" placeholder="9XXXXXXXX"/></div>
    <div class="field"><label>Ubicación</label><input id="mp-location" placeholder="Ej: Gamarra, Lima"/></div>
    <div class="field"><label>Tipo</label><select id="mp-type"><option>Importador</option><option>Mayorista</option><option>Fabricante</option><option>Otro</option></select></div>
    <div class="field"><label>Calidad (1–5)</label><select id="mp-quality"><option value="5">5 — Excelente</option><option value="4">4 — Bueno</option><option value="3" selected>3 — Regular</option><option value="2">2 — Bajo</option><option value="1">1 — Malo</option></select></div>
    <div class="field ffield"><label>Observaciones</label><input id="mp-notes" placeholder="Condiciones, tiempos..."/></div>
  </div>
  <div class="ffoot"><button class="btn btn-ghost" onclick="closeModal('modal-prov')">Cancelar</button><button class="btn btn-p" onclick="saveProvider()">Guardar proveedor</button></div>
</div></div>

<!-- MODAL CATEGORÍA -->
<div class="modal-bg" id="modal-cat"><div class="modal">
  <div class="modal-head"><div class="modal-title" id="modal-cat-title">Nueva categoría</div><button class="modal-close" onclick="closeModal('modal-cat')">×</button></div>
  <input type="hidden" id="mcat-id">
  <div class="fgrid">
    <div class="field"><label>Nombre *</label><input id="mcat-name" placeholder="Ej: Cocina"/></div>
    <div class="field ffield"><label>Descripción</label><input id="mcat-desc" placeholder="Descripción opcional"/></div>
  </div>
  <div class="ffoot"><button class="btn btn-ghost" onclick="closeModal('modal-cat')">Cancelar</button><button class="btn btn-p" onclick="saveCategory()">Guardar</button></div>
</div></div>

<div class="toast" id="toast"></div>

<script>
const API='';
function toast(msg,type='ok'){const t=document.getElementById('toast');t.textContent=msg;t.className=`toast ${type} show`;setTimeout(()=>t.classList.remove('show'),3000)}
async function api(method,path,body){const opts={method,headers:{'Content-Type':'application/json'}};if(body)opts.body=JSON.stringify(body);const r=await fetch(API+path,opts);const json=await r.json();if(!r.ok||!json.ok)throw new Error(json.message||'Error');return json.data}
function fmt(n){return'S/ '+parseFloat(n||0).toFixed(2)}
function gv(id){return document.getElementById(id).value.trim()}
function gn(id){return parseFloat(document.getElementById(id).value)||0}
function gi(id){return parseInt(document.getElementById(id).value)||0}
function sv(id,v){document.getElementById(id).value=v||''}
function filterTb(tbId,q){q=q.toLowerCase();document.querySelectorAll(`#${tbId} tr`).forEach(r=>{r.style.display=!q||r.textContent.toLowerCase().includes(q)?'':'none'})}
function filterCol(tbId,col,val){document.querySelectorAll(`#${tbId} tr`).forEach(r=>{const cells=r.querySelectorAll('td');r.style.display=!val||(cells[col]&&cells[col].textContent.trim()===val)?'':'none'})}
function go(name,el){document.querySelectorAll('.section').forEach(s=>s.classList.remove('on'));document.querySelectorAll('.ni').forEach(n=>n.classList.remove('on'));document.getElementById('sec-'+name).classList.add('on');el.classList.add('on')}
function openF(id){document.getElementById(id).classList.add('on')}
function closeF(id){document.getElementById(id).classList.remove('on')}
function openModal(id){document.getElementById(id).classList.add('on')}
function closeModal(id){const el=document.getElementById(id);el.classList.remove('on');el.querySelectorAll('input:not([type=hidden]),select,textarea').forEach(e=>e.value='');const h=el.querySelector('[type=hidden]');if(h)h.value=''}

// DASHBOARD
async function loadDashboard(){
  try{
    const d=await api('GET','/api/stats');
    document.getElementById('kpi-dash').innerHTML=`
      <div class="kpi"><div class="kpi-label">Productos</div><div class="kpi-val">${d.total_products}</div><div class="kpi-sub">en catálogo</div></div>
      <div class="kpi"><div class="kpi-label">Valor inventario</div><div class="kpi-val o" style="font-size:20px">${fmt(d.inventory_value)}</div></div>
      <div class="kpi"><div class="kpi-label">Ventas</div><div class="kpi-val">${d.total_sales}</div><div class="kpi-sub">registradas</div></div>
      <div class="kpi"><div class="kpi-label">Ingresos totales</div><div class="kpi-val g" style="font-size:20px">${fmt(d.total_income)}</div></div>
      <div class="kpi"><div class="kpi-label">Ganancias</div><div class="kpi-val g" style="font-size:20px">${fmt(d.total_profit)}</div></div>
      <div class="kpi"><div class="kpi-label">Ticket promedio</div><div class="kpi-val" style="font-size:20px">${fmt(d.avg_ticket)}</div></div>
      <div class="kpi"><div class="kpi-label">Clientes</div><div class="kpi-val">${d.total_clients}</div></div>
      <div class="kpi"><div class="kpi-label">Conversión</div><div class="kpi-val">${d.conversion_rate}%</div><div class="kpi-bar"><div class="kpi-fill g" style="width:${d.conversion_rate}%"></div></div></div>
      <div class="kpi"><div class="kpi-label">Stock bajo</div><div class="kpi-val ${d.low_stock>0?'r':''}">${d.low_stock}</div><div class="kpi-sub">productos</div></div>
      <div class="kpi"><div class="kpi-label">Margen prom.</div><div class="kpi-val">${d.avg_margin}%</div></div>
    `;
    const tp=document.getElementById('top-products');
    if(d.top_products&&d.top_products.length){tp.innerHTML=d.top_products.map((p,i)=>`<div class="top-item"><div class="top-rank">#${i+1}</div><div class="top-name">${p.name}</div><div><span class="top-val">${fmt(p.revenue)}</span><span class="top-qty">${p.qty} uds.</span></div></div>`).join('');}
    else tp.innerHTML='<div class="empty"><p>Sin ventas aún</p></div>';
    const cc=document.getElementById('channels-chart');
    if(d.channels&&d.channels.length){const max=Math.max(...d.channels.map(c=>c.count));cc.innerHTML=d.channels.map(c=>`<div class="ch-item"><div class="ch-name">${c.channel}</div><div class="ch-bar-wrap"><div class="ch-bar" style="width:${Math.round(c.count/max*100)}%"></div></div><div class="ch-n">${c.count}</div></div>`).join('');}
    else cc.innerHTML='<div class="empty"><p>Sin ventas aún</p></div>';
  }catch(e){console.error(e)}
}

// CATEGORÍAS
let allCategories=[];
async function loadCategories(){
  try{
    allCategories=await api('GET','/api/categories');
    const tb=document.getElementById('tb-cat');const em=document.getElementById('empty-cat');
    em.style.display=allCategories.length?'none':'block';
    tb.innerHTML=allCategories.map(c=>`<tr><td style="color:var(--text-3);font-family:'DM Mono',monospace;font-size:11px">#${c.id}</td><td class="cn">${c.name}</td><td style="color:var(--text-2)">${c.description||'—'}</td><td>${c.product_count||0}</td><td><button class="btn btn-sm btn-edit" onclick='editCategory(${JSON.stringify(c)})'>Editar</button> <button class="btn btn-sm btn-del" onclick="delCategory(${c.id})">Eliminar</button></td></tr>`).join('');
    const opts=allCategories.map(c=>`<option value="${c.id}">${c.name}</option>`).join('');
    ['fi-cat','filter-cat'].forEach(id=>{const el=document.getElementById(id);if(el){const blank=id==='filter-cat'?'<option value="">Todas las categorías</option>':'<option value="">Seleccionar...</option>';el.innerHTML=blank+opts}});
    await refreshProductSelect();
  }catch(e){console.error(e)}
}
async function saveCategory(){
  const id=gv('mcat-id');const body={name:gv('mcat-name'),description:gv('mcat-desc')};
  if(!body.name){toast('El nombre es requerido','er');return}
  try{id?await api('PUT',`/api/categories/${id}`,body):await api('POST','/api/categories',body);toast(id?'Categoría actualizada':'Categoría creada');closeModal('modal-cat');loadCategories();}catch(e){toast(e.message,'er')}
}
function editCategory(c){sv('mcat-id',c.id);sv('mcat-name',c.name);sv('mcat-desc',c.description);document.getElementById('modal-cat-title').textContent='Editar categoría';openModal('modal-cat')}
async function delCategory(id){if(!confirm('¿Eliminar esta categoría?'))return;try{await api('DELETE',`/api/categories/${id}`);toast('Categoría eliminada');loadCategories();}catch(e){toast(e.message,'er')}}

// INVENTARIO
let allProducts=[];
async function loadInventory(){
  try{
    allProducts=await api('GET','/api/products');
    const tb=document.getElementById('tb-inv');const em=document.getElementById('empty-inv');
    const al=document.getElementById('alert-inv');const badge=document.getElementById('badge-stock');
    const bajo=allProducts.filter(p=>p.stock_alert).length;
    const avgM=allProducts.length?Math.round(allProducts.reduce((a,p)=>a+p.margin_pct,0)/allProducts.length):0;
    const valInv=allProducts.reduce((a,p)=>a+(p.cost_unit*p.stock_current),0);
    document.getElementById('kpi-inv').innerHTML=`
      <div class="kpi"><div class="kpi-label">Total productos</div><div class="kpi-val">${allProducts.length}</div></div>
      <div class="kpi"><div class="kpi-label">Margen promedio</div><div class="kpi-val">${avgM}%</div></div>
      <div class="kpi"><div class="kpi-label">Valor inventario</div><div class="kpi-val o" style="font-size:20px">${fmt(valInv)}</div></div>
      <div class="kpi"><div class="kpi-label">Stock bajo</div><div class="kpi-val ${bajo>0?'r':''}">${bajo}</div></div>`;
    al.style.display=bajo>0?'flex':'none';badge.style.display=bajo>0?'inline':'none';badge.textContent=bajo;
    em.style.display=allProducts.length?'none':'block';
    tb.innerHTML=allProducts.map(p=>{const mb=p.margin_pct>=40?'bg':p.margin_pct>=20?'ba':'br';const sb=p.stock_current<=0?'br':p.stock_alert?'ba':'bg';
      return`<tr><td><span class="cn">${p.name}</span><span class="cc">${p.id}</span></td><td><span class="badge bgr">${p.category||'—'}</span></td><td>${fmt(p.cost_unit)}</td><td>${fmt(p.price_retail)}</td><td><span class="badge ${mb}">${p.margin_pct}%</span></td><td><span class="badge ${sb}">${p.stock_current<=0?'Sin stock':p.stock_alert?'⚠ '+p.stock_current:p.stock_current}</span></td><td style="color:var(--text-2);font-size:12px">${p.provider||'—'}</td><td><span class="badge ${p.status==='Activo'?'bg':'bgr'}">${p.status}</span></td><td><button class="btn btn-sm btn-edit" onclick='editProduct(${JSON.stringify(p)})'>Editar</button> <button class="btn btn-sm btn-del" onclick="delProduct('${p.id}')">Eliminar</button></td></tr>`}).join('');
    refreshProviderSelect();refreshProductSelect();
  }catch(e){console.error(e)}
}
function calcMargin(){const cost=gn('fi-cost'),retail=gn('fi-retail');const m=retail>0?Math.round((retail-cost)/retail*100):0;document.getElementById('fi-margin').value=retail>0?m+'%':'—'}
async function saveProduct(){
  const id=gv('fi-id');
  const body={name:gv('fi-name'),color:gv('fi-color'),category_id:document.getElementById('fi-cat').value||null,provider_id:document.getElementById('fi-prov').value||null,cost_unit:gn('fi-cost'),price_retail:gn('fi-retail'),price_wholesale:gn('fi-wholesale'),stock_current:gi('fi-stock'),stock_min:gi('fi-smin')||1,location:gv('fi-loc'),notes:gv('fi-notes')};
  if(!body.name||!body.cost_unit||!body.price_retail){toast('Nombre, costo y precio son requeridos','er');return}
  try{id?await api('PUT',`/api/products/${id}`,body):await api('POST','/api/products',body);toast(id?'Producto actualizado':'Producto creado');closeF('finv');resetProductForm();loadInventory();}catch(e){toast(e.message,'er')}
}
function editProduct(p){sv('fi-id',p.id);sv('fi-name',p.name);sv('fi-color',p.color||'');sv('fi-cost',p.cost_unit);sv('fi-retail',p.price_retail);sv('fi-wholesale',p.price_wholesale||0);sv('fi-stock',p.stock_current);sv('fi-smin',p.stock_min);sv('fi-loc',p.location||'');sv('fi-notes',p.notes||'');if(p.category_id)document.getElementById('fi-cat').value=p.category_id;if(p.provider_id)document.getElementById('fi-prov').value=p.provider_id;calcMargin();document.getElementById('finv-title').textContent='Editar — '+p.id;openF('finv')}
function resetProductForm(){['fi-id','fi-name','fi-color','fi-cost','fi-retail','fi-wholesale','fi-stock','fi-smin','fi-loc','fi-notes','fi-margin'].forEach(id=>sv(id,''));document.getElementById('fi-cat').value='';document.getElementById('fi-prov').value='';document.getElementById('finv-title').textContent='Nuevo producto'}
async function delProduct(id){if(!confirm('¿Eliminar producto '+id+'?'))return;try{await api('DELETE',`/api/products/${id}`);toast('Producto eliminado');loadInventory();}catch(e){toast(e.message,'er')}}

// VENTAS
async function loadSales(){
  try{
    const ss=await api('GET','/api/sales');const tb=document.getElementById('tb-ventas');const em=document.getElementById('empty-ventas');
    const totalI=ss.reduce((a,s)=>a+s.total_income,0);const totalP=ss.reduce((a,s)=>a+s.total_profit,0);const ticket=ss.length?totalI/ss.length:0;
    document.getElementById('kpi-ventas').innerHTML=`<div class="kpi"><div class="kpi-label">Total ventas</div><div class="kpi-val">${ss.length}</div></div><div class="kpi"><div class="kpi-label">Ingresos totales</div><div class="kpi-val g" style="font-size:20px">${fmt(totalI)}</div></div><div class="kpi"><div class="kpi-label">Ganancias totales</div><div class="kpi-val g" style="font-size:20px">${fmt(totalP)}</div></div><div class="kpi"><div class="kpi-label">Ticket promedio</div><div class="kpi-val" style="font-size:20px">${fmt(ticket)}</div></div>`;
    em.style.display=ss.length?'none':'block';
    tb.innerHTML=ss.map(s=>`<tr><td style="font-size:12px;color:var(--text-2)">${s.date}</td><td><span class="cc">${s.id}</span></td><td class="cn">${s.client_name||'—'}</td><td style="font-size:12px">${s.details.map(d=>d.product_name+' x'+d.quantity).join(', ')}</td><td style="font-weight:600">${fmt(s.total_income)}</td><td style="color:var(--green-dark);font-weight:600">${fmt(s.total_profit)}</td><td><span class="badge bb">${(s.channel||'').split(' ')[0]}</span></td><td>${s.payment_method||'—'}</td><td><button class="btn btn-sm btn-del" onclick="delSale('${s.id}')">Elim.</button></td></tr>`).join('');
  }catch(e){console.error(e)}
}

let clientSearchTimer;
async function searchClient(q){
  const dd=document.getElementById('cli-dd');
  if(!q||q.length<2){dd.classList.remove('on');return}
  clearTimeout(clientSearchTimer);
  clientSearchTimer=setTimeout(async()=>{
    try{const cs=await api('GET',`/api/clients/search?q=${encodeURIComponent(q)}`);
      if(!cs||!cs.length){dd.innerHTML='<div class="cli-opt" style="color:var(--text-3)">Sin resultados — crea el cliente primero</div>';dd.classList.add('on');return}
      dd.innerHTML=cs.map(c=>`<div class="cli-opt" onclick="selectClient('${c.id}','${c.name}','${c.phone||''}','${c.status}')"><div class="cli-opt-name">${c.name} <span class="badge ${c.status==='Frecuente'?'bg':'bb'}" style="font-size:10px">${c.status}</span></div><div class="cli-opt-sub">${c.phone||''} · ${c.total_orders} pedidos · ${fmt(c.total_spent)}</div></div>`).join('');
      dd.classList.add('on');
    }catch(e){}
  },300);
}
function selectClient(id,name,phone,status){sv('fv-cli-id',id);sv('fv-cli-display',name+(phone?' — '+phone:'')+(status?' ('+status+')':''));sv('fv-cli-search','');document.getElementById('cli-dd').classList.remove('on')}
document.addEventListener('click',e=>{if(!e.target.closest('.cli-wrap'))document.getElementById('cli-dd').classList.remove('on')});

let saleItems=[];
function addSaleItem(){saleItems.push({product_id:'',quantity:1,price:0});renderSaleItems()}
function removeSaleItem(idx){saleItems.splice(idx,1);renderSaleItems();calcSaleTotal()}
function renderSaleItems(){
  const c=document.getElementById('sale-items');
  c.innerHTML=saleItems.map((item,idx)=>`<div class="sale-row"><select class="si-prod" onchange="onProdSelect(this,${idx})"><option value="">Seleccionar producto...</option>${allProducts.filter(p=>p.stock_current>0||p.id===item.product_id).map(p=>`<option value="${p.id}" data-price="${p.price_retail}"${item.product_id===p.id?' selected':''}>${p.name} (stock: ${p.stock_current})</option>`).join('')}</select><input type="number" min="1" value="${item.quantity}" oninput="saleItems[${idx}].quantity=parseInt(this.value)||1;calcSaleTotal()"/><input type="number" min="0" step="0.01" value="${item.price}" oninput="saleItems[${idx}].price=parseFloat(this.value)||0;calcSaleTotal()"/><button class="rm-btn" onclick="removeSaleItem(${idx})">×</button></div>`).join('');
}
function onProdSelect(sel,idx){const opt=sel.options[sel.selectedIndex];saleItems[idx].product_id=sel.value;saleItems[idx].price=parseFloat(opt.dataset.price)||0;renderSaleItems();calcSaleTotal()}
function calcSaleTotal(){const t=saleItems.reduce((a,i)=>a+(i.price*i.quantity),0);document.getElementById('sale-total-val').textContent=fmt(t+gn('fv-delivery'))}
async function saveSale(){
  const clientId=gv('fv-cli-id');
  if(!clientId){toast('Selecciona un cliente primero','er');return}
  const items=saleItems.filter(i=>i.product_id&&i.quantity>0);
  if(!items.length){toast('Agrega al menos un producto','er');return}
  try{
    await api('POST','/api/sales',{client_id:clientId,items:items.map(i=>({product_id:i.product_id,quantity:i.quantity,price_at_sale:i.price})),channel:gv('fv-channel'),payment_method:gv('fv-payment'),delivery_type:gv('fv-delivery-type'),delivery_cost:gn('fv-delivery'),notes:gv('fv-notes')});
    toast('Venta registrada y stock actualizado');
    closeF('fventa');saleItems=[];renderSaleItems();sv('fv-cli-id','');sv('fv-cli-display','');sv('fv-cli-search','');
    loadSales();loadInventory();loadDashboard();
  }catch(e){toast(e.message,'er')}
}
async function delSale(id){if(!confirm('¿Eliminar venta? El stock se revertirá.'))return;try{await api('DELETE',`/api/sales/${id}`);toast('Venta eliminada y stock revertido');loadSales();loadInventory();loadDashboard();}catch(e){toast(e.message,'er')}}

// CLIENTES
async function loadClients(){
  try{
    const cs=await api('GET','/api/clients');const tb=document.getElementById('tb-cli');const em=document.getElementById('empty-cli');
    const totalG=cs.reduce((a,c)=>a+c.total_spent,0);const frec=cs.filter(c=>c.status==='Frecuente').length;
    document.getElementById('kpi-cli').innerHTML=`<div class="kpi"><div class="kpi-label">Total clientes</div><div class="kpi-val">${cs.length}</div></div><div class="kpi"><div class="kpi-label">Frecuentes</div><div class="kpi-val g">${frec}</div></div><div class="kpi"><div class="kpi-label">Total facturado</div><div class="kpi-val g" style="font-size:20px">${fmt(totalG)}</div></div><div class="kpi"><div class="kpi-label">LTV promedio</div><div class="kpi-val" style="font-size:20px">${cs.length?fmt(totalG/cs.length):'S/ 0'}</div></div>`;
    em.style.display=cs.length?'none':'block';
    tb.innerHTML=cs.map(c=>{const bc=c.status==='Frecuente'?'bg':c.status==='Activo'?'bb':'bgr';return`<tr><td><span class="cn">${c.name}</span><span class="cc">${c.id}</span></td><td>${c.phone||'—'}</td><td>${c.district||'—'}</td><td style="text-align:center">${c.total_orders}</td><td style="font-weight:600">${fmt(c.total_spent)}</td><td><span class="badge ${bc}">${c.status}</span></td><td style="font-size:12px;color:var(--text-2)">${c.created_at||'—'}</td><td><button class="btn btn-sm btn-edit" onclick='editClient(${JSON.stringify(c)})'>Editar</button> <button class="btn btn-sm btn-del" onclick="delClient('${c.id}')">Eliminar</button></td></tr>`}).join('');
  }catch(e){console.error(e)}
}
async function saveClient(){
  const id=gv('mc-id');const body={name:gv('mc-name'),phone:gv('mc-phone'),district:gv('mc-district'),status:gv('mc-status'),notes:gv('mc-notes')};
  if(!body.name){toast('El nombre es requerido','er');return}
  try{const c=id?await api('PUT',`/api/clients/${id}`,body):await api('POST','/api/clients',body);toast(id?'Cliente actualizado':'Cliente registrado');closeModal('modal-cli');if(!id)selectClient(c.id,c.name,c.phone||'',c.status);loadClients();}catch(e){toast(e.message,'er')}
}
function editClient(c){sv('mc-id',c.id);sv('mc-name',c.name);sv('mc-phone',c.phone||'');sv('mc-district',c.district||'');sv('mc-notes',c.notes||'');document.getElementById('mc-status').value=c.status||'Activo';document.getElementById('modal-cli-title').textContent='Editar cliente — '+c.id;openModal('modal-cli')}
async function delClient(id){if(!confirm('¿Eliminar este cliente?'))return;try{await api('DELETE',`/api/clients/${id}`);toast('Cliente eliminado');loadClients();}catch(e){toast(e.message,'er')}}

// CONSULTAS
async function refreshProductSelect(){const sel=document.getElementById('fiq-prod');if(!sel)return;sel.innerHTML='<option value="">Seleccionar producto...</option>'+allProducts.map(p=>`<option value="${p.id}">${p.name}</option>`).join('')}
async function loadInquiries(){
  try{
    const qs=await api('GET','/api/inquiries');const tb=document.getElementById('tb-inq');const em=document.getElementById('empty-inq');
    const compraron=qs.filter(q=>q.result==='Compró').length;const conv=qs.length?Math.round(compraron/qs.length*100):0;
    document.getElementById('kpi-inq').innerHTML=`<div class="kpi"><div class="kpi-label">Consultas</div><div class="kpi-val">${qs.length}</div></div><div class="kpi"><div class="kpi-label">Conversión</div><div class="kpi-val">${conv}%</div><div class="kpi-bar"><div class="kpi-fill g" style="width:${conv}%"></div></div></div><div class="kpi"><div class="kpi-label">Compraron</div><div class="kpi-val g">${compraron}</div></div><div class="kpi"><div class="kpi-label">No compraron</div><div class="kpi-val r">${qs.length-compraron}</div></div>`;
    em.style.display=qs.length?'none':'block';
    tb.innerHTML=qs.map(q=>{const rb=q.result==='Compró'?'bg':q.result==='Pendiente'?'ba':'br';return`<tr><td style="font-size:12px;color:var(--text-2)">${q.date}</td><td class="cn">${q.product_name||'—'}</td><td>${q.client_name||'—'}</td><td><span class="badge bb">${(q.channel||'').split(' ')[0]}</span></td><td style="font-size:12px">${q.question||'—'}</td><td><span class="badge ${rb}">${q.result}</span></td><td style="font-size:12px;color:var(--text-2)">${q.no_buy_reason||'—'}</td></tr>`}).join('');
  }catch(e){console.error(e)}
}
async function saveInquiry(){
  const sel=document.getElementById('fiq-prod');const prodId=sel.value;const prodName=prodId?sel.options[sel.selectedIndex].text:'';
  if(!prodName){toast('Selecciona un producto','er');return}
  try{await api('POST','/api/inquiries',{product_id:prodId||null,product_name:prodName,client_name:gv('fiq-cli'),channel:gv('fiq-canal'),question:gv('fiq-preg'),result:gv('fiq-res'),no_buy_reason:gv('fiq-mot')});toast('Consulta registrada');closeF('finq');['fiq-cli','fiq-preg','fiq-mot'].forEach(id=>sv(id,''));document.getElementById('fiq-prod').value='';loadInquiries();}catch(e){toast(e.message,'er')}
}

// PROVEEDORES
async function loadProviders(){
  try{
    const ps=await api('GET','/api/providers');const tb=document.getElementById('tb-prov');const em=document.getElementById('empty-prov');
    em.style.display=ps.length?'none':'block';
    tb.innerHTML=ps.map(p=>{const stars='★'.repeat(p.quality||0)+'☆'.repeat(5-(p.quality||0));return`<tr><td><span class="cn">${p.name}</span><span class="cc">${p.id}</span></td><td>${p.contact||'—'}</td><td>${p.phone||'—'}</td><td>${p.location||'—'}</td><td><span class="badge bgr">${p.type||'—'}</span></td><td style="color:var(--amber)">${stars}</td><td><button class="btn btn-sm btn-edit" onclick='editProvider(${JSON.stringify(p)})'>Editar</button> <button class="btn btn-sm btn-del" onclick="delProvider('${p.id}')">Eliminar</button></td></tr>`}).join('');
    refreshProviderSelect(ps);
  }catch(e){console.error(e)}
}
function refreshProviderSelect(ps){
  const sel=document.getElementById('fi-prov');if(!sel)return;
  const data=ps||allProducts;
  fetch('/api/providers').then(r=>r.json()).then(j=>{if(j.ok){sel.innerHTML='<option value="">Seleccionar...</option>'+j.data.map(p=>`<option value="${p.id}">${p.name}</option>`).join('')}});
}
async function saveProvider(){
  const id=gv('mp-id');const body={name:gv('mp-name'),contact:gv('mp-contact'),phone:gv('mp-phone'),location:gv('mp-location'),type:gv('mp-type'),quality:parseInt(document.getElementById('mp-quality').value)||3,notes:gv('mp-notes')};
  if(!body.name){toast('El nombre es requerido','er');return}
  try{id?await api('PUT',`/api/providers/${id}`,body):await api('POST','/api/providers',body);toast(id?'Proveedor actualizado':'Proveedor guardado');closeModal('modal-prov');loadProviders();}catch(e){toast(e.message,'er')}
}
function editProvider(p){sv('mp-id',p.id);sv('mp-name',p.name);sv('mp-contact',p.contact||'');sv('mp-phone',p.phone||'');sv('mp-location',p.location||'');sv('mp-notes',p.notes||'');document.getElementById('mp-type').value=p.type||'Importador';document.getElementById('mp-quality').value=p.quality||3;document.getElementById('modal-prov-title').textContent='Editar proveedor — '+p.id;openModal('modal-prov')}
async function delProvider(id){if(!confirm('¿Eliminar este proveedor?'))return;try{await api('DELETE',`/api/providers/${id}`);toast('Proveedor eliminado');loadProviders();}catch(e){toast(e.message,'er')}}

function exportExcel(){window.location.href='/api/export/excel';toast('Descargando Excel...')}

async function init(){
  addSaleItem();
  await loadCategories();
  await loadInventory();
  await loadSales();
  await loadClients();
  await loadInquiries();
  await loadProviders();
  await loadDashboard();
}
init();
</script>
</body>
</html>
